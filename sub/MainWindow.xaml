<Window x:Class="sub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sub"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <StackPanel>
            <TextBox x:Name="txtvalue1" Margin="4" Height="40" Width="40"></TextBox>
            <TextBox x:Name="txtvalue2" Margin="4" Height="40" Width="40"></TextBox>
            <Button x:Name="btnresult" Click="btnresult_Click" Height="40"  Width="40"></Button>
        </StackPanel>
    </StackPanel>
</Window>
